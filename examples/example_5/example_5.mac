/gps/ene/mono 80 keV
/run/beamOn {NEVT}
/gps/ene/mono 90 keV
/run/beamOn {NEVT}
/gps/ene/mono 100 keV
/run/beamOn {NEVT_big}
/gps/ene/mono 200 keV
/run/beamOn {NEVT_big}
/gps/ene/mono 300 keV
/run/beamOn {NEVT_big}
/gps/ene/mono 400 keV
/run/beamOn {NEVT_big}
